<?php
session_start();

if ($_SERVER['REQUEST_METHOD'] == 'POST') {
    $ip = $_POST['ip'];
    $ports = explode(',', $_POST['ports']);
    $results = [];

    foreach ($ports as $port) {
        $port = trim($port);
        $connection = @fsockopen($ip, $port, $errno, $errstr, 1);
        if (is_resource($connection)) {
            $results[$port] = 'Open';
            fclose($connection);
        } else {
            $results[$port] = 'Closed';
        }
    }

    $_SESSION['results'] = $results;
    header('Location: results.php');
    exit();
}

